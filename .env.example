# Web server (3000 often busy — default in code is 3080)
PORT=3080

# Session-Login (mind. 16 Zeichen). Dann entfällt Basic-Auth für die App.
SESSION_SECRET=
# Hinter HTTPS / Nginx: SESSION_COOKIE_SECURE=1 setzen
SESSION_COOKIE_SECURE=
# Basis-URL für Links in E-Mails (Zugangsdaten)
APP_BASE_URL=https://pvl.lifeco.at
# Einmalig ersten Admin per UI: gleicher Wert in login.html „Setup-Token“
SETUP_TOKEN=
# Optional: Passwort-Vergessen auf login.html (mind. 16 Zeichen); gleicher Wert im Formular „Reset-Token“
PASSWORD_RESET_TOKEN=

# HTTP Basic Auth (ganze App). User + entweder Klartext (nur lokal) oder bcrypt-Hash:
BASIC_AUTH_USER=
# lokal/dev optional:
BASIC_AUTH_PASS=
# produktion: Hash mit  npm run hash-basic-password -- deinpasswort  erzeugen, Klartext-Zeile weglassen
BASIC_AUTH_PASS_BCRYPT=

# --- Leads (SQLite) ---
# Optional: absoluter Pfad zur SQLite-Datei (Default: data/leads.db relativ zum Projekt)
SQLITE_LEADS_DB=

# --- IMAP (poller) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=Leads
# Optional: volle IMAP-Mailbox für Lead-Mails (Default INBOX.${IMAP_FOLDER})
# IMAP_LEADS_MAILBOX=INBOX.Leads
# NOORTEC: Archiv nach Import — Default `Leads/Archiv_Importiert`. Sonst voller Pfad setzen.
# IMAP_ARCHIVE_MAILBOX=INBOX.Leads.Archiv_Importiert
# Klassisch: Archiv als Unterordner der Lead-Mailbox (Punkt/Slash): IMAP_ARCHIVE_RELATIVE_TO_LEADS=1
# IMAP_ARCHIVE_SUBFOLDER=Archiv_Importiert
# Einmal-Cleanup: max. geprüfte Mails pro Start (Default 200, max 500)
# IMAP_CLEANUP_MAX_MESSAGES=200

# --- Lead extraction (NOORTEC: Default DeepSeek, OpenAI-kompatibel) ---
# openai-compatible | deepseek | openai | anthropic
LLM_PROVIDER=openai-compatible
DEEPSEEK_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
# Fallback wenn kein DEEPSEEK_API_KEY
# OPENAI_API_KEY=
LLM_MODEL=deepseek-chat
# 0 = kein response_format json_object (z. B. anderer OpenAI-kompatibler Provider)
# LLM_JSON_OBJECT=1

# Nur bei LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

MY_NAME=
MY_EMAIL=
MY_PHONE=
EMAIL_SIGNATURE=

# --- E-Mail-Versand (Zugangsdaten, Kundenbestätigung nach neuem Lead) ---
SMTP_HOST=
SMTP_PORT=587
# 1 = TLS direkt (Port 465), sonst STARTTLS auf 587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Absender (falls leer: SMTP_USER)
MAIL_FROM=

# --- REONIC (optional: bei Status „Termin vereinbart“ → POST h360 Create Request) ---
# Basis-Host ohne Slash; Pfad: /integrations/{REONIC_CLIENT_ID}/h360/request/create
REONIC_API_BASE_URL=https://app.reonic.de
REONIC_CLIENT_ID=
# API-Key: als HTTP-Basic (API-Key als User, leeres Passwort) Base64-codiert, oder Wert mit Präfix „Basic “ / „Bearer “
REONIC_API_KEY=
# Optional: vollständige URL zum Create-Endpoint (ersetzt Basis + Client-ID)
# REONIC_API_URL=

# Admin API: Bearer für POST /api/admin/users ohne Session
ADMIN_TOKEN=
