# Web server (3000 often busy — default in code is 3080)
PORT=3080

# Session-Login (mind. 16 Zeichen). Dann entfällt Basic-Auth für die App.
SESSION_SECRET=
# Hinter HTTPS / Nginx: SESSION_COOKIE_SECURE=1 setzen
SESSION_COOKIE_SECURE=
# Basis-URL für Links in E-Mails (Zugangsdaten)
APP_BASE_URL=https://pvl.lifeco.at
# Einmalig ersten Admin per UI: gleicher Wert in login.html „Setup-Token“
SETUP_TOKEN=
# Optional: Passwort-Vergessen auf login.html (mind. 16 Zeichen); gleicher Wert im Formular „Reset-Token“
PASSWORD_RESET_TOKEN=

# HTTP Basic Auth (ganze App). User + entweder Klartext (nur lokal) oder bcrypt-Hash:
BASIC_AUTH_USER=
# lokal/dev optional:
BASIC_AUTH_PASS=
# produktion: Hash mit  npm run hash-basic-password -- deinpasswort  erzeugen, Klartext-Zeile weglassen
BASIC_AUTH_PASS_BCRYPT=

# --- IMAP (poller) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=Leads

# --- Lead extraction ---
# anthropic | openai-compatible (DeepSeek, OpenRouter, OpenAI, etc.)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# optional override (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=

# If LLM_PROVIDER=openai-compatible (e.g. DeepSeek: base https://api.deepseek.com , model deepseek-chat)
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
LLM_MODEL=deepseek-chat

# --- Google (Sheets + optional Calendar/Gmail via same OAuth token) ---
# OAuth-Client (Alternative zur Datei auth/google-credentials.json — wenn beides gesetzt, gewinnt .env):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; Standard: http://127.0.0.1:3334/oauth2callback (wie npm run oauth-setup)
# GOOGLE_OAUTH_REDIRECT_URI=
# Lead-Tabelle: ID = der Teil der Sheet-URL …/spreadsheets/d/<ID>/edit — nur hier setzen, nie im Quelltext hartcodiert (siehe src/sheets.js: process.env.GOOGLE_SPREADSHEET_ID).
GOOGLE_SPREADSHEET_ID=
# Name des Blatts mit den Leads (wie in Google Sheets unten). Leer/Default: Sheet1. Groß/Klein egal. Wenn der Name in der Mappe nicht existiert, wird bei genau einem Blatt dieses Blatt genutzt.
GOOGLE_SHEET_NAME=
# Zweites Blatt (z. B. alte Leads) – nur Karte/Lesestift; Schreiben nur in GOOGLE_SHEET_NAME
GOOGLE_SHEET_LEGACY_NAME=
GOOGLE_ARCHIVE_SPREADSHEET_ID=
# Tab in der Archiv-Mappe, wohin archivierte Zeilen geschrieben werden (Default im Code nur falls unset: Cosimo)
GOOGLE_ARCHIVE_SHEET_NAME=
GOOGLE_CALENDAR_ID=primary

MY_NAME=
MY_EMAIL=
MY_PHONE=
EMAIL_SIGNATURE=

# --- E-Mail-Versand (Zugangsdaten, ggf. Kalender-Bestätigung) ---
# Option A: SMTP (z. B. vertrieb@… beim Provider — IMAP ist nur für den Poller-Empfang)
SMTP_HOST=
SMTP_PORT=587
# 1 = TLS direkt (Port 465), sonst STARTTLS auf 587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Absender (falls leer: SMTP_USER)
MAIL_FROM=

# Admin API: Bearer für POST /api/admin/users ohne Session
ADMIN_TOKEN=
