# Web server (3000 often busy — default in code is 3080)
PORT=3080

# Session-Login (mind. 16 Zeichen). Dann entfällt Basic-Auth für die App.
SESSION_SECRET=
# Hinter HTTPS / Nginx: SESSION_COOKIE_SECURE=1 setzen
SESSION_COOKIE_SECURE=
# Basis-URL für Links in E-Mails (Zugangsdaten)
APP_BASE_URL=https://pvl.lifeco.at
# Einmalig ersten Admin per UI: gleicher Wert in login.html „Setup-Token“
SETUP_TOKEN=

# HTTP Basic Auth (ganze App). User + entweder Klartext (nur lokal) oder bcrypt-Hash:
BASIC_AUTH_USER=
# lokal/dev optional:
BASIC_AUTH_PASS=
# produktion: Hash mit  npm run hash-basic-password -- deinpasswort  erzeugen, Klartext-Zeile weglassen
BASIC_AUTH_PASS_BCRYPT=

# --- IMAP (poller) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=Leads

# --- Lead extraction ---
# anthropic | openai-compatible (DeepSeek, OpenRouter, OpenAI, etc.)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# optional override (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=

# If LLM_PROVIDER=openai-compatible (e.g. DeepSeek: base https://api.deepseek.com , model deepseek-chat)
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
LLM_MODEL=deepseek-chat

# --- Google (Sheets + optional Calendar/Gmail via same OAuth token) ---
# Diese Spreadsheet-ID + Blattname: hier landen alle neuen Leads (Poller append unten).
GOOGLE_SPREADSHEET_ID=
# Exakter Tabellenblatt-Name (z. B. Tabellenblatt1). Default im Code: Tabellenblatt2
GOOGLE_SHEET_NAME=
# Zweites Blatt (z. B. alte Leads) – nur Karte/Lesestift; Schreiben nur in GOOGLE_SHEET_NAME
GOOGLE_SHEET_LEGACY_NAME=
GOOGLE_ARCHIVE_SPREADSHEET_ID=
GOOGLE_CALENDAR_ID=primary

MY_NAME=
MY_EMAIL=
MY_PHONE=
EMAIL_SIGNATURE=

# --- E-Mail-Versand (Zugangsdaten, ggf. Kalender-Bestätigung) ---
# Option A: SMTP (z. B. vertrieb@… beim Provider — IMAP ist nur für den Poller-Empfang)
SMTP_HOST=
SMTP_PORT=587
# 1 = TLS direkt (Port 465), sonst STARTTLS auf 587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Absender (falls leer: SMTP_USER)
MAIL_FROM=

# Admin API: Bearer für POST /api/admin/users ohne Session
ADMIN_TOKEN=
